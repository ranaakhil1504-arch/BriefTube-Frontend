
{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install && cd pdf-compressor && npm install",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "pdf-compressor/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "pdf-compressor/dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/pdf-compressor/(.*)",
      "destination": "/pdf-compressor/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/favicon.svg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800"
        }
      ]
    }
  ]
}
